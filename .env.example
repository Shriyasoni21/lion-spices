# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lion-spices?retryWrites=true&w=majority

# JWT secret
JWT_SECRET=change_this_secret

# Razorpay keys (leave empty to enable UPI fallback)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# UPI ID for fallback payments
UPI_ID=lionspices@upi

# SMTP settings for sending emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=support@lionspices.com
CONTACT_EMAIL=support@lionspices.com

# Frontend / Backend settings for local development
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,https://lion-spices.netlify.app,https://lionspices.netlify.app

# Production placeholders
MONGODB_ATLAS_URI=
JWT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
